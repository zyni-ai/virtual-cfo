{
  "enabledPlugins": {
    "laravel-boost@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(php artisan *)",
      "Bash(vendor/bin/pint *)",
      "Bash(vendor/bin/phpstan *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git worktree *)",
      "Bash(git mv *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(gh label *)",
      "Bash(gh api *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(php *)",
      "mcp__laravel-boost__database-schema",
      "mcp__laravel-boost__database-query",
      "mcp__laravel-boost__search-docs",
      "mcp__laravel-boost__tinker",
      "mcp__laravel-boost__list-routes",
      "mcp__laravel-boost__application-info",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-php.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/phpstan-check.sh"
          }
        ]
      }
    ]
  }
}
