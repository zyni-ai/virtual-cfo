includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/
    level: 6

    reportUnmatchedIgnoredErrors: true

    ignoreErrors:
        # Timestamp nullsafe (nunomaduro/larastan#1580) - genuinely unfixable
        - identifier: nullsafe.neverNull
