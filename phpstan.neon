includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
    level: 6

    reportUnmatchedIgnoredErrors: true

    ignoreErrors:
        # Pivot properties (larastan/larastan#883) - genuinely unfixable
        -
            message: '#Access to an undefined property Illuminate\\Database\\Eloquent\\Relations\\Pivot::\$[a-zA-Z_]+#'

        # Timestamp nullsafe (nunomaduro/larastan#1580) - genuinely unfixable
        - identifier: nullsafe.neverNull
