APP_NAME="Virtual CFO"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=virtual_cfo
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

OPENROUTER_API_KEY=

AI_PARSING_MODEL=deepseek/deepseek-v3.2
AI_MATCHING_MODEL=mistralai/mistral-large-latest

DB_SSLMODE=prefer

ZOHO_REDIRECT_URI=https://virtual-cfo.test/connectors/zoho/callback

MAILGUN_SECRET=<your-mailgun-api-key>
MAILGUN_INBOX_DOMAIN=inbox.yourdomain.com